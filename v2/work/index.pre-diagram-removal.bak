220.6" cy="159" r="4.86" fill="#CC6C05" fill-opacity="0.60"/> <circle cx="147.8" cy="174" r="4.95" fill="#CC6C05" fill-opacity="0.66"/> <circle cx="212.2" cy="177" r="4.95" fill="#CC6C05" fill-opacity="0.66"/> <circle cx="156.1" cy="192" r="5.05" fill="#CC6C05" fill-opacity="0.71"/> <circle cx="203.9" cy="195" r="5.05" fill="#CC6C05" fill-opacity="0.71"/> <circle cx="164.4" cy="210" r="5.15" fill="#CC6C05" fill-opacity="0.77"/> <circle cx="195.6" cy="213" r="5.15" fill="#CC6C05" fill-opacity="0.77"/> <circle cx="172.8" cy="228" r="5.25" fill="#CC6C05" fill-opacity="0.82"/> <circle cx="187.2" cy="231" r="5.25" fill="#CC6C05" fill-opacity="0.82"/> <circle cx="178" cy="240" r="5.9" fill="#CC6C05" fill-opacity="0.92"/> <circle cx="182" cy="242" r="6.0" fill="#CC6C05" fill-opacity="0.95"/> <circle cx="180" cy="236" r="5.7" fill="#CC6C05" fill-opacity="0.9"/> <circle cx="180" cy="248" r="5.4" fill="#CC6C05" fill-opacity="0.88"/> </g> <!-- single output line on mobile --> <circle cx="180" cy="258" r="5.8" fill="#CC6C05" fill-opacity="0.93"/><circle cx="180" cy="288" r="5.5" fill="#CC6C05" fill-opacity="0.8"/><circle cx="180" cy="320" r="5.2" fill="#CC6C05" fill-opacity="0.66"/><circle cx="180" cy="354" r="4.9" fill="#CC6C05" fill-opacity="0.52"/><circle cx="180" cy="390" r="4.6" fill="#CC6C05" fill-opacity="0.38"/><circle cx="180" cy="428" r="4.3" fill="#CC6C05" fill-opacity="0.25"/><circle cx="180" cy="468" r="4.0" fill="#CC6C05" fill-opacity="0.15"/> <text x="102" y="44" font-size="14" font-weight="700" fill="#1B2A4A">Lived Judgment</text> <text x="146" y="246" font-size="14" font-weight="700" fill="#1B2A4A">Signal Loss</text> <text x="96" y="548" font-size="14" font-weight="700" fill="#1B2A4A">Weak Market Signal</text> </svg> </div> <p class="anti-pattern-transition">Weak signal → weak demand → weak pricing power.</p> </div> </section> <section class="phase-gates"> <div class="container"> <h2>The REIGNITE<span class="tm">™</span> <span>Phase Gates</span></h2> <p class="section-sub">C3 Process: each gate closes risk before the next one opens. This is how strategy becomes execution without chaos.</p> <div class="phase-track"> <div class="phase-gate"><div class="gate-dot"><i class="fas fa-search"></i></div><h4>Gate 1: Diagnose</h4><p>Map value leaks and current message distortion.</p></div> <div class="phase-gate"><div class="gate-dot"><i class="fas fa-drafting-compass"></i></div><h4>Gate 2: Design</h4><p>Build category, offer architecture, and price logic.</p></div> <div class="phase-gate"><div class="gate-dot"><i class="fas fa-vial-circle-check"></i></div><h4>Gate 3: Validate</h4><p>Pressure-test proof, objection handling, and fit criteria.</p></div> <div class="phase-gate"><div class="gate-dot"><i class="fas fa-rocket"></i></div><h4>Gate 4: Deploy</h4><p>Launch controlled outreach with clear pipeline targets.</p></div> </div> </div> </section> <section class="framework" id="architecture"> <div class="container"> <h2>Inside the REIGNITE<span class="tm">™</span> <span>System</span></h2> <p class="section-sub">Option B (Blueprint Grid): a structural map showing how judgment becomes a commercial engine through linked architecture layers.</p> <style>.blueprint-wrap{max-width:980px;margin:0 auto;background:linear-gradient(160deg,#101d34,#162748);border:1px solid rgba(242,179,111,.26);border-radius:14px;padding:16px 16px 14px;box-shadow:0 14px 32px rgba(9,16,30,.35)}.bp-title{display:flex;justify-content:space-between;align-items:center;color:#f2b36f;font-size:.72rem;font-weight:800;letter-spacing:.9px;text-transform:uppercase;margin-bottom:10px}.bp-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}.bp-cell{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.14);border-radius:10px;padding:10px 10px 9px;min-height:84px;position:relative}.bp-cell h4{margin:0 0 6px;color:#fff;font-size:.8rem;letter-spacing:.3px}.bp-cell p{margin:0;color:rgba(255,255,255,.74);font-size:.72rem;line-height:1.35}.bp-row-label{position:absolute;left:-9px;top:8px;background:#cc6c05;color:#fff;font-size:.58rem;font-weight:800;letter-spacing:.55px;text-transform:uppercase;padding:3px 6px;border-radius:999px}.bp-connectors{margin:10px 0 8px;border-top:1px dashed rgba(242,179,111,.45);position:relative;height:16px}.bp-connectors:before,.bp-connectors:after{content:'';position:absolute;top:-4px;width:8px;height:8px;border-radius:50%;background:#f2b36f}.bp-connectors:before{left:22%}.bp-connectors:after{left:72%}.bp-note{margin-top:10px;color:rgba(255,255,255,.72);font-size:.74rem;text-align:center}.bp-legend{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:8px}.bp-legend span{font-size:.64rem;color:rgba(255,255,255,.78);border:1px solid rgba(255,255,255,.16);padding:4px 7px;border-radius:999px}.bp-legend b{color:#f2b36f}@media (max-width:860px){.bp-grid{grid-template-columns:1fr}.bp-row-label{position:static;display:inline-block;margin-bottom:6px}.bp-connectors{display:none}}</style> <div class="blueprint-wrap"> <div class="bp-title"><span>Intellectual Asset Architecture Blueprint</span><span>v2.0</span></div> <div class="bp-grid"> <article class="bp-cell"><span class="bp-row-label">Layer 1</span><h4>Identity & Judgment Extraction</h4><p>Extract core operating judgment, pattern-recognition logic, and strategic differentiation signals.</p></article> <article class="bp-cell"><span class="bp-row-label">Layer 1</span><h4>Sweet Spot + ICP Precision</h4><p>Define where authority is strongest and who values it most at premium pricing.</p></article> <article class="bp-cell"><span class="bp-row-label">Layer 1</span><h4>Category Language</h4><p>Codify language that signals strategic depth without sounding generic.</p></article> </div> <div class="bp-connectors"></div> <div class="bp-grid"> <article class="bp-cell"><span class="bp-row-label">Layer 2</span><h4>Offer Architecture</h4><p>Package judgment into a clear flagship structure with boundaries and outcomes.</p></article> <article class="bp-cell"><span class="bp-row-label">Layer 2</span><h4>CAOS Flow</h4><p>Concept → Audience → Offer → Sales mapped as one coherent conversion system.</p></article> <article class="bp-cell"><span class="bp-row-label">Layer 2</span><h4>Pricing Logic</h4><p>Shift from effort-based rates to architecture-driven value framing.</p></article> </div> <div class="bp-connectors"></div> <div class="bp-grid"> <article class="bp-cell"><span class="bp-row-label">Layer 3</span><h4>Leverage Layer</h4><p>Build delivery and signal systems that reduce dependence on constant presence.</p></article> <article class="bp-cell"><span class="bp-row-label">Layer 3</span><h4>Demand Engine</h4><p>Run repeatable demand rhythms tied to the codified architecture.</p></article> <article class="bp-cell"><span class="bp-row-label">Layer 3</span><h4>Asset Output</h4><p>Convert expertise into defensible intellectual assets with long-term pricing power.</p></article> </div> <div class="bp-legend"><span><b>Extract</b> signal</span><span><b>Structure</b> value</span><span><b>Leverage</b> output</span></div> <p class="bp-note">Blueprint logic: no layer scales if the layer above it is undefined.</p> </div> </div> </section> <!-- Contrast Matrix --> <section class="contrast-matrix"> <div class="container"> <h2>Transformation <span>Mirror Bars</span></h2> <p class="section-sub">C4 Transformation: left bar reflects old identity, right bar reflects upgraded operating standard.</p> <div class="mirror-bars"> <div class="mirror-row"><div class="mirror-left"><span>Generalist advisor identity</span></div><div class="mirror-right"><span>Category authority with strategic IP</span></div></div> <div class="mirror-row"><div class="mirror-left"><span>Custom proposal every time</span></div><div class="mirror-right"><span>Structured flagship offer architecture</span></div></div> <div class="mirror-row"><div class="mirror-left"><span>Pricing tied to effort</span></div><div class="mirror-right"><span>Pricing tied to strategic outcome</span></div></div> <div class="mirror-row"><div class="mirror-left"><span>Inconsistent demand and messaging</span></div><div class="mirror-right"><span>Predictable pipeline and clear signal</span></div></div> </div> <div class="matrix-cta"> <a href="#momentum-score" class="btn btn-gold"> <i class="fas fa-drafting-compass"></i> Apply for Private Advisory </a> <span class="micro-assurance">Limited private slots each month. Qualified applicants only.</span> </div> </div> </section> <section class="results"> <div class="container"> <h2>Client <span>Proof</span></h2> <p class="section-sub">C8 Commercialization Pipeline: a straight conversion line from signal to signed premium engagement.</p> <div class="straight-pipeline"><div class="pipe-step"><i class="fas fa-broadcast-tower"></i><span>Signal</span></div><div class="pipe-arrow">→</div><div class="pipe-step"><i class="fas fa-comments-dollar"></i><span>Qualified Call</span></div><div class="pipe-arrow">→</div><div class="pipe-step"><i class="fas fa-file-signature"></i><span>Offer Alignment</span></div><div class="pipe-arrow">→</div><div class="pipe-step"><i class="fas fa-handshake"></i><span>Signed Engagement</span></div></div>

