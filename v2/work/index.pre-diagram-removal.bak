<!DOCTYPE html>
<html lang="en">
<head> <meta charset="UTF-8"> <meta name="viewport" content="width=device-width, initial-scale=1.0"> <title>Steven Tshakatumba | Reignite Advisors</title> <link rel="preconnect" href="https://fonts.googleapis.com"> <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"> <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"> <style> :root { --navy: #1B2A4A; --navy-dark: #0F1A2E; --gold: #CC6C05; --gold-light: #F2B36F; --gold-dim: #B15F19; --white: #FFFFFF; --cream: #FAF9F7; --light-gray: #F5F5F5; --text-dark: #1A1A1A; --text-muted: #666666; } * { margin: 0; padding: 0; box-sizing: border-box; } html { scroll-behavior: smooth; overflow-x: hidden; } body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--white); color: var(--text-dark); line-height: 1.65; overflow-x: hidden; width: 100%; } body > * { max-width: 100%; } h1, h2, h3, h4 { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; } a { text-decoration: none; transition: all 0.3s ease; } .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; width: 100%; } .btn { display: inline-flex; align-items: center; gap: 8px; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; border: none; } .btn:not(.nav-cta) { --cta-width: 264px; --cta-height: 52px; --cta-padding-x: 24px; --cta-font-size: 1rem; --cta-radius: 8px; width: var(--cta-width); min-width: var(--cta-width); height: var(--cta-height); padding: 0 var(--cta-padding-x); font-size: var(--cta-font-size); line-height: 1; border-radius: var(--cta-radius); justify-content: center; white-space: nowrap; } .btn-gold { background: var(--gold); color: var(--white); } .btn-gold:hover { background: #B15F19; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(204,108,5,0.35); } .btn-navy { background: var(--navy); color: var(--white); } .btn-navy:hover { background: var(--navy-dark); transform: translateY(-2px); } .btn-outline-gold { background: transparent; color: var(--gold-light); border: 2px solid rgba(229,212,161,0.85); } .btn-outline-gold:hover { background: rgba(229,212,161,0.1); border-color: var(--gold-light); transform: translateY(-2px); } .tm { display:inline-block; font-size:0.5em; line-height:0; vertical-align:super; position:relative; top:-0.45em; margin:0; padding:0; color:inherit; letter-spacing:0; } .hero-ctas .btn { flex: 0 0 var(--cta-width); } .hero-ctas .btn-outline-gold .tm { display:inline-block !important; margin:0 !important; padding:0 !important; font-size:0.52em !important; line-height:0 !important; vertical-align:super !important; position:relative !important; top:-0.45em !important; color:currentColor !important; letter-spacing:0 !important; } /* Navigation */ nav { position: fixed; top: 0; left: 0; right: 0; background: rgba(255,255,255,0.97); backdrop-filter: blur(12px); z-index: 1000; padding: 12px 0; border-bottom: 1px solid rgba(27,42,74,0.08); } nav .container { display: flex; justify-content: space-between; align-items: center; } .logo-group { display: flex; flex-direction: column; } .logo-mark { display: flex; align-items: baseline; gap: 0; } .logo { font-size: 1.65rem; font-weight: 800; color: var(--navy); letter-spacing: 2px; text-transform: uppercase; } .logo-dot { color: var(--gold); font-size: 1.75rem; line-height: 1; margin-left: -2px; } .logo-sub { font-size: 0.58rem; font-weight: 600; color: var(--gold-dim); text-transform: uppercase; letter-spacing: 4px; margin-top: 2px; } nav .btn.nav-cta { width: auto; min-width: 0; max-width: none; height: 42px; padding: 0 16px; font-size: 0.88rem; line-height: 1; border-radius: 8px; white-space: nowrap; justify-content: center; font-weight: 700; gap: 7px; align-items: center; } nav .btn.nav-cta i { font-size: 0.95em; line-height: 1; display: inline-flex; align-items: center; justify-content: center; } /* Hero Section */ .hero { display: grid; grid-template-columns: 1fr 1fr; min-height: 62vh; } .hero-left { background: var(--navy); padding: 96px 44px 34px; display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden; } .hero-left::before { content: ''; position: absolute; top: -100px; right: -100px; width: 350px; height: 350px; background: radial-gradient(circle, rgba(204,108,5,0.18) 0%, transparent 60%); } .hero-left::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 120px; background: linear-gradient(to top, rgba(27,42,74,0.5) 0%, transparent 100%); } .hero-tag { color: var(--gold); font-size: 0.7rem; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 16px; position: relative; z-index: 1; } .hero-left h1 { font-size: 2.5rem; line-height: 1.15; color: var(--white); margin-bottom: 18px; font-weight: 800; letter-spacing: -0.5px; position: relative; z-index: 1; } .hero-left h1 .highlight { color: var(--gold); } .hero-sub { color: rgba(255,255,255,0.75); font-size: 1rem; margin-bottom: 28px; max-width: 480px; line-height: 1.7; position: relative; z-index: 1; } .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; position: relative; z-index: 1; } .hero-right { position: relative; overflow: hidden; padding: 30px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--navy) 0%, #243B5A 100%); } .hero-image-wrapper { position: relative; width: 100%; max-width: 320px; display: flex; justify-content: center; } .hero-image-wrapper::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 85%; height: 90%; background: radial-gradient(ellipse at center, rgba(204,108,5,0.15) 0%, transparent 70%); pointer-events: none; z-index: 1; } .hero-image-wrapper img { width: 100%; height: auto; aspect-ratio: 3/4; object-fit: contain; object-position: center bottom; -webkit-mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%); mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%); } .hero-wordmark { position: absolute; top: 84%; left: 50%; transform: translate(-50%, -50%); font-size: 5rem; font-weight: 800; color: rgba(255,255,255,0.1); letter-spacing: -2px; line-height: 1; text-align: center; width: 100%; pointer-events: none; } /* Trust Strip */ .trust-strip { background: var(--navy); padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,0.05); } .trust-strip p { text-align: center; color: rgba(255,255,255,0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2.5px; margin-bottom: 18px; font-weight: 600; } .trust-marquee { overflow: hidden; position: relative; } .trust-marquee::before, .trust-marquee::after { content: ''; position: absolute; top: 0; bottom: 0; width: 60px; z-index: 2; pointer-events: none; } .trust-marquee::before { left: 0; background: linear-gradient(to right, var(--navy), transparent); } .trust-marquee::after { right: 0; background: linear-gradient(to left, var(--navy), transparent); } .trust-logos { display: flex; width: max-content; align-items: center; gap: 40px; animation: trustScroll 30s linear infinite; } .trust-marquee:hover .trust-logos { animation-play-state: paused; } .trust-logo {
  height: 34px;
  width: auto;
  max-width: 150px;
  object-fit: contain;
  filter: none !important;
  opacity: 1 !important;
  mix-blend-mode: normal;
  background: transparent;
  padding: 0;
  border-radius: 0;
  border: 0;
} .trust-logo img { height: 100%; max-width: 110px; object-fit: contain; filter: grayscale(100%) brightness(1.4) opacity(0.75); transition: all 0.3s ease; } .trust-logo img:hover { filter: grayscale(100%) brightness(1.6) opacity(1); } .trust-logo-fallback { color: rgba(255,255,255,0.65); font-weight: 600; font-size: 0.85rem; letter-spacing: 0.5px; } @keyframes trustScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } } /* Why This Matters - with diagram */ .why { padding: 88px 0; background: var(--white); } .why h2 { font-size: 1.9rem; text-align: center; margin-bottom: 10px; color: var(--navy); letter-spacing: -0.5px; } .why h2 span { color: var(--gold); } .why .section-sub { text-align: center; color: var(--text-muted); margin-bottom: 18px; max-width: 700px; margin-left: auto; margin-right: auto; } .why-bullets { list-style: none; display: grid; gap: 10px; max-width: 520px; margin: 0 auto 34px; } .why-bullets li { display: flex; justify-content: center; gap: 8px; color: var(--navy); font-weight: 600; font-size: 0.9rem; text-align: center; } .why-bullets li span { color: var(--gold-dim); } .why-visual { max-width: 520px; margin: 0 auto 45px; position: relative; } .flywheel { position: relative; width: 280px; height: 280px; margin: 0 auto; } .flywheel-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 90px; height: 90px; background: var(--navy); border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 2; box-shadow: 0 8px 30px rgba(27,42,74,0.3); } .flywheel-center span { color: var(--gold); font-weight: 800; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; } .flywheel-ring { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 200px; height: 200px; border: 2px dashed rgba(204,108,5,0.35); border-radius: 50%; animation: spin 30s linear infinite; } .flywheel-node { position: absolute; width: 72px; height: 72px; background: var(--cream); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 20px rgba(27,42,74,0.12); border: 2px solid var(--gold); z-index: 2; } .flywheel-node i { color: var(--navy); font-size: 1.4rem; } .flywheel-node.n1 { top: calc(50% - 100px); left: 50%; transform: translate(-50%, -50%); } .flywheel-node.n2 { top: calc(50% + 50px); left: calc(50% - 86.6px); transform: translate(-50%, -50%); } .flywheel-node.n3 { top: calc(50% + 50px); left: calc(50% + 86.6px); transform: translate(-50%, -50%); } @keyframes spin { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } } .flywheel-arrows { position: absolute; top: 0; left: 0; z-index: 1; } .why-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; max-width: 860px; margin: 0 auto; } .why-card { padding: 28px 24px; border-radius: 12px; border: 1px solid rgba(27,42,74,0.1); } .why-card h3 { font-size: 1.1rem; margin-bottom: 14px; } .why-card ul { list-style: none; display: grid; gap: 10px; } .why-card li { font-size: 0.92rem; display: flex; align-items: center; gap: 10px; } .why-card li::before { content: '•'; font-size: 1.2rem; line-height: 1; } .why-card-left { background: #fff7f7; border-color: #f1d6d6; } .why-card-left h3, .why-card-left li { color: #8a4343; } .why-card-right { background: var(--navy); border-color: var(--gold); } .why-card-right h3, .why-card-right li { color: var(--gold-light); } /* Reignite Advantage */ .advantage { padding: 88px 0; background: var(--cream); } .advantage h2 { font-size: 1.9rem; text-align: center; margin-bottom: 10px; color: var(--navy); letter-spacing: -0.5px; } .advantage h2 span { color: var(--gold); } .advantage .section-sub { text-align: center; color: var(--text-muted); margin-bottom: 45px; max-width: 560px; margin-left: auto; margin-right: auto; } .advantage-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; } .advantage-card { background: var(--white); padding: 32px 26px; border-radius: 12px; text-align: center; transition: all 0.3s ease; border: 1px solid rgba(27,42,74,0.08); } .advantage-card:hover { border-color: var(--gold); transform: translateY(-4px); box-shadow: 0 12px 35px rgba(27,42,74,0.1); } .advantage-icon { width: 56px; height: 56px; background: linear-gradient(135deg, var(--navy) 0%, #2A3D5C 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 18px; } .advantage-icon i { color: var(--gold); font-size: 1.4rem; } .advantage-card h3 { font-size: 1.1rem; margin-bottom: 8px; color: var(--navy); } .advantage-card p { color: var(--text-muted); font-size: 0.88rem; } /* Method */ /* Removed - replaced by Framework pathway section */ /* Results Carousel */ .results { padding: 88px 0; background: var(--navy); position: relative; overflow: hidden; } .results::before { content: ''; position: absolute; top: -80px; right: -80px; width: 250px; height: 250px; background: radial-gradient(circle, rgba(204,108,5,0.1) 0%, transparent 60%); } .results h2 { font-size: 1.9rem; text-align: center; margin-bottom: 10px; color: var(--white); letter-spacing: -0.5px; } .results h2 span { color: var(--gold); } .results .section-sub { text-align: center; color: rgba(255,255,255,0.5); margin-bottom: 40px; max-width: 560px; margin-left: auto; margin-right: auto; } .carousel-wrapper { position: relative; max-width: 700px; margin: 0 auto; } .carousel-track { display: flex; gap: 20px; overflow: hidden; scroll-behavior: smooth; } .carousel-track::-webkit-scrollbar { display: none; } .carousel-card { flex: 0 0 100%; min-width: 100%; background: rgba(255,255,255,0.05); padding: 26px 20px; border-radius: 12px; text-align: center; border: 1px solid rgba(255,255,255,0.08); transition: all 0.3s ease; } .carousel-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(204,108,5,0.3); } .carousel-card img { width: 54px; height: 54px; border-radius: 50%; margin-bottom: 12px; object-fit: cover; border: 2px solid var(--gold); } .carousel-card h3 { font-size: 1rem; margin-bottom: 6px; color: var(--gold-light); } .carousel-card p { color: rgba(255,255,255,0.66); font-size: 0.82rem; line-height: 1.6; margin-bottom: 12px; } .result-shift { padding: 10px 14px; background: rgba(204,108,5,0.15); border-radius: 6px; font-size: 0.78rem; font-weight: 600; color: var(--gold-light); border-left: 3px solid var(--gold); text-align: left; } .result-placeholder { margin-top: 10px; font-size: 0.73rem; color: rgba(255,255,255,0.58); font-style: italic; letter-spacing: 0.2px; text-align: left; } .result-profile { margin-top: 14px; display: flex; align-items: center; gap: 10px; justify-content: flex-start; } .result-profile img { width: 42px; height: 42px; margin: 0; border-width: 1.5px; } .result-profile-meta { text-align: left; } .result-profile-name { color: var(--white); font-size: 0.82rem; font-weight: 700; line-height: 1.2; } .result-role { color: var(--gold); font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; } .results-wall { margin-top: 18px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; } .results-chip { border: 1px solid rgba(255,255,255,0.14); border-radius: 999px; padding: 8px 12px; font-size: 0.72rem; color: rgba(255,255,255,0.72); background: rgba(255,255,255,0.04); text-align: center; } .carousel-nav { display: flex; justify-content: center; gap: 12px; margin-top: 30px; } .carousel-btn { width: 44px; height: 44px; border-radius: 50%; background: var(--gold); color: var(--white); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1rem; transition: all 0.3s ease; } .carousel-btn:hover { background: #B15F19; transform: scale(1.05); } .results-trust-line { text-align: center; margin-top: 18px; color: rgba(255,255,255,0.72); font-size: 0.78rem; letter-spacing: 0.3px; } .straight-pipeline{max-width:900px;margin:0 auto 26px;display:grid;grid-template-columns:1fr auto 1fr auto 1fr auto 1fr;gap:8px;align-items:center}.pipe-step{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px}.pipe-step i{color:var(--gold-light);font-size:1rem}.pipe-step span{color:var(--white);font-size:.76rem;font-weight:600;letter-spacing:.4px;text-transform:uppercase;text-align:center}.pipe-arrow{color:rgba(242,179,111,.9);font-size:1.1rem;font-weight:700;text-align:center} @media (max-width:900px){.straight-pipeline{grid-template-columns:1fr 1fr;gap:10px}.pipe-arrow{display:none}} /* Who */ .who { padding: 88px 0; background: var(--cream); } .who h2 { font-size: 1.9rem; text-align: center; margin-bottom: 10px; color: var(--navy); letter-spacing: -0.5px; } .who h2 span { color: var(--gold); } .who .section-sub { text-align: center; color: var(--text-muted); margin-bottom: 40px; max-width: 560px; margin-left: auto; margin-right: auto; } .who-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 720px; margin: 0 auto; } .who-item { display: flex; align-items: flex-start; gap: 12px; padding: 18px; background: var(--white); border-radius: 10px; border: 1px solid rgba(27,42,74,0.06); } .who-item i { color: var(--gold); margin-top: 3px; font-size: 0.9rem; } .who-item p { font-size: 0.92rem; color: var(--text-dark); } /* Lead Capture */ .lead-capture { padding: 60px 0; background: var(--white); text-align: center; border-top: 1px solid var(--light-gray); } .lead-capture h2 { font-size: 1.7rem; margin-bottom: 10px; color: var(--navy); } .lead-capture h2 span { color: var(--gold); } .lead-capture p { color: var(--text-muted); margin-bottom: 26px; } .lead-form { display: flex; gap: 12px; justify-content: center; max-width: 480px; margin: 0 auto; flex-wrap: wrap; } .lead-form input { flex: 1; min-width: 220px; padding: 14px 18px; border: 2px solid #E5E5E5; border-radius: 6px; font-size: 1rem; font-family: inherit; } .lead-form input:focus { outline: none; border-color: var(--gold); } /* FAQ */ .faq { padding: 88px 0; background: var(--cream); } .faq h2 { font-size: 1.9rem; text-align: center; margin-bottom: 10px; color: var(--navy); letter-spacing: -0.5px; } .faq h2 span { color: var(--gold); } .faq .section-sub { text-align: center; color: var(--text-muted); margin-bottom: 40px; max-width: 560px; margin-left: auto; margin-right: auto; } .faq-list { max-width: 660px; margin: 0 auto; } .faq-item { border-bottom: 1px solid rgba(27,42,74,0.08); } .faq-question { padding: 18px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; } .faq-question h4 { font-size: 0.98rem; font-weight: 600; color: var(--navy); } .faq-question i { color: var(--gold); transition: transform 0.3s ease; font-size: 0.8rem; } .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; } .faq-answer p { color: var(--text-muted); font-size: 0.88rem; padding-bottom: 18px; } .faq-item.active .faq-answer { max-height: 140px; } .faq-item.active .faq-question i { transform: rotate(180deg); } /* Final CTA */ .final-cta { padding: 60px 0; background: var(--navy); text-align: center; color: var(--white); position: relative; overflow: hidden; } .final-cta::before { content: ''; position: absolute; top: -80px; left: -80px; width: 250px; height: 250px; background: radial-gradient(circle, rgba(204,108,5,0.15) 0%, transparent 60%); } .final-cta::after { content: ''; position: absolute; bottom: -60px; right: -60px; width: 220px; height: 220px; background: radial-gradient(circle, rgba(204,108,5,0.1) 0%, transparent 60%); } .final-cta h2 { font-size: 1.8rem; margin-bottom: 10px; position: relative; } .final-cta p { color: rgba(255,255,255,0.7); margin-bottom: 24px; font-size: 1rem; position: relative; } /* Footer */ footer { background: var(--navy-dark); padding: 36px 0 26px; color: rgba(255,255,255,0.45); text-align: center; } footer .logo-group { align-items: center; margin-bottom: 6px; } footer .logo { color: var(--white); font-size: 1.4rem; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; } footer .logo-dot { font-size: 1.5rem; margin-left: -2px; } footer .logo-sub { color: var(--gold); font-size: 0.52rem; letter-spacing: 4px; } footer .tagline { color: var(--gold); margin-bottom: 14px; font-size: 0.8rem; font-weight: 600; letter-spacing: 1px; } footer .copyright { font-size: 0.65rem; margin-top: 16px; opacity: 0.4; } /* Responsive */ @media (max-width: 900px) { .hero { grid-template-columns: 1fr; min-height: auto; } .hero-left { padding: 96px 24px 32px; min-height: auto; justify-content: flex-start; overflow: visible; } .hero-left h1 { line-height: 1.2; } .hero-right { height: 420px; } .hero-right img { max-width: 300px; } .why-grid, .advantage-grid { grid-template-columns: 1fr 1fr; } .who-grid { grid-template-columns: 1fr; } .lead-form { flex-direction: column; padding: 0 20px; } .carousel-card { flex: 0 0 100%; } } @media (max-width: 600px) { .why-grid, .advantage-grid { grid-template-columns: 1fr; } .hero-left { padding-top: 104px; } .hero-left h1 { font-size: 1.9rem; } .hero-ctas { flex-direction: column; align-items: stretch; } .btn:not(.nav-cta) { width: 100%; min-width: 0; height: 52px; flex: 0 0 52px; font-size: 1rem; } .trust-logos { gap: 24px; } .results-wall { grid-template-columns: 1fr; } .flywheel { transform: scale(0.85); } .why-visual { max-width: 360px; } .flywheel-label { font-size: 0.63rem; letter-spacing: 0.7px; } .triangle-wrap { width: 100%; max-width: 320px; margin-left: auto; margin-right: auto; display: flex; justify-content: center; } .triangle-core { width: 320px; height: 229px; margin-left: auto; margin-right: auto; left: 50%; transform: translateX(-50%); } .triangle-node { width: 32px; height: 32px; } .triangle-node i { font-size: 0.82rem; } .triangle-node.clarity { top: 20px; left: 160px; } .triangle-node.offer { top: 223px; left: 43px; } .triangle-node.demand { top: 223px; left: 277px; } .triangle-label { font-size: 0.62rem; letter-spacing: 0.8px; } .triangle-label.clarity { top: -10px; left: 160px; } .triangle-label.offer { top: 245px; left: 43px; } .triangle-label.demand { top: 245px; left: 277px; } .triangle-center { width: 96px; height: 96px; font-size: 0.65rem; } .triangle-flow-dot { width: 7px; height: 7px; top: 20px; left: 160px; } .triangle-flow-dot.dot-2 { width: 7px; height: 7px; } @keyframes triangleOrbit { 0% { top: 20px; left: 160px; transform: translate(-50%, -50%); } 33.333% { top: 223px; left: 277px; transform: translate(-50%, -50%); } 66.666% { top: 223px; left: 43px; transform: translate(-50%, -50%); } 100% { top: 20px; left: 160px; transform: translate(-50%, -50%); } } } /* Anti-Pattern Stack */ .anti-pattern { padding: 70px 0; background: var(--white); border-bottom: 1px solid var(--light-gray); } .anti-pattern h2 { font-size: 1.7rem; text-align: center; margin-bottom: 10px; color: var(--navy); letter-spacing: -0.5px; } .anti-pattern .section-sub { text-align: center; color: var(--text-muted); margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; } .anti-pattern-stack { max-width: 560px; margin: 0 auto; background: var(--light-gray); border-radius: 10px; padding: 8px; } .anti-pattern-row { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: var(--white); border-radius: 8px; margin-bottom: 6px; border: 1px solid rgba(27,42,74,0.06); } .anti-pattern-row:last-child { margin-bottom: 0; } .anti-pattern-row i { color: var(--gold-dim); font-size: 0.85rem; width: 18px; text-align: center; } .anti-pattern-row span { color: var(--text-muted); font-size: 0.92rem; } .anti-pattern-transition { text-align: center; margin-top: 24px; color: var(--text-muted); font-size: 0.9rem; font-style: italic; } .noise-filter{display:grid;grid-template-columns:1fr 120px 1fr;gap:18px;align-items:center;max-width:940px;margin:0 auto}.noise-lane{background:var(--light-gray);border:1px solid rgba(27,42,74,.08);border-radius:12px;padding:16px}.noise-lane h4{font-size:.78rem;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;color:var(--navy)}.noise-chip{display:flex;gap:10px;align-items:flex-start;padding:10px 12px;background:#fff;border-radius:8px;border:1px solid rgba(27,42,74,.08);margin-bottom:8px}.noise-chip:last-child{margin-bottom:0}.noise-chip i{color:var(--gold-dim);font-size:.8rem;margin-top:3px}.noise-chip span{font-size:.84rem;color:var(--text-muted);line-height:1.4}.noise-core{position:relative;width:120px;height:120px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:linear-gradient(145deg,#13213b,var(--navy));border:2px solid rgba(204,108,5,.72)}.noise-core-ring{position:absolute;inset:10px;border:1px dashed rgba(242,179,111,.65);border-radius:50%}.noise-core-label{position:relative;color:var(--gold-light);font-weight:700;font-size:.72rem;letter-spacing:.8px;text-transform:uppercase} @media (max-width:900px){.noise-filter{grid-template-columns:1fr;gap:12px}.noise-core{margin:2px auto 6px}} /* C3 Phase Gates */ .phase-gates{padding:76px 0;background:var(--cream);border-top:1px solid rgba(27,42,74,.06);border-bottom:1px solid rgba(27,42,74,.06)}.phase-gates h2{font-size:1.8rem;text-align:center;margin-bottom:10px;color:var(--navy);letter-spacing:-.4px}.phase-gates h2 span{color:var(--gold)}.phase-gates .section-sub{text-align:center;color:var(--text-muted);margin-bottom:32px;max-width:650px;margin-left:auto;margin-right:auto}.phase-track{max-width:920px;margin:0 auto;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;position:relative}.phase-track:before{content:'';position:absolute;left:8%;right:8%;top:34px;border-top:2px dashed rgba(204,108,5,.4)}.phase-gate{position:relative;background:#fff;border:1px solid rgba(27,42,74,.1);border-radius:12px;padding:52px 14px 14px;text-align:center}.gate-dot{position:absolute;top:16px;left:50%;transform:translateX(-50%);width:36px;height:36px;border-radius:50%;background:var(--navy);border:2px solid var(--gold);display:flex;align-items:center;justify-content:center;color:var(--gold-light)}.phase-gate h4{font-size:.82rem;text-transform:uppercase;letter-spacing:.7px;color:var(--navy);margin-bottom:6px}.phase-gate p{font-size:.8rem;color:var(--text-muted);line-height:1.35} @media (max-width:900px){.phase-track{grid-template-columns:1fr 1fr}.phase-track:before{display:none}} @media (max-width:600px){.phase-track{grid-template-columns:1fr}} /* Contrast Matrix */ .contrast-matrix { padding: 80px 0; background: var(--cream); } .contrast-matrix h2 { font-size: 1.9rem; text-align: center; margin-bottom: 10px; color: var(--navy); letter-spacing: -0.5px; } .contrast-matrix h2 span { color: var(--gold); } .contrast-matrix .section-sub { text-align: center; color: var(--text-muted); margin-bottom: 40px; max-width: 560px; margin-left: auto; margin-right: auto; } .matrix-container { max-width: 800px; margin: 0 auto; } .matrix-header { display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-bottom: 6px; } .matrix-header-left { background: #E8E8E8; padding: 14px 20px; text-align: center; border-radius: 8px 0 0 8px; font-weight: 600; font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; } .matrix-header-right { background: var(--navy); padding: 14px 20px; text-align: center; border-radius: 0 8px 8px 0; font-weight: 700; font-size: 0.85rem; color: var(--gold); text-transform: uppercase; letter-spacing: 1px; border: 2px solid var(--navy); } .matrix-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-bottom: 6px; } .matrix-row-left { background: var(--white); padding: 18px 20px; border-radius: 8px 0 0 8px; display: flex; align-items: center; gap: 10px; border: 1px solid rgba(27,42,74,0.08); } .matrix-row-left i { color: var(--gold-dim); font-size: 0.8rem; } .matrix-row-left span { color: var(--text-muted); font-size: 0.88rem; } .matrix-row-right { background: var(--navy); padding: 18px 20px; border-radius: 0 8px 8px 0; display: flex; align-items: center; gap: 10px; border: 2px solid var(--navy); border-left: none; } .matrix-row-right i { color: var(--gold); font-size: 0.8rem; } .matrix-row-right span { color: var(--white); font-size: 0.88rem; font-weight: 500; } .matrix-cta { text-align: center; margin-top: 36px; } .matrix-cta .btn { margin-bottom: 10px; } .matrix-cta .micro-assurance { color: var(--text-muted); } .mirror-bars{max-width:840px;margin:0 auto;display:grid;gap:10px}.mirror-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}.mirror-left,.mirror-right{padding:16px 18px;border-radius:10px;display:flex;align-items:center;min-height:62px}.mirror-left{background:#fff;border:1px solid rgba(27,42,74,.1);position:relative}.mirror-left:before{content:'';position:absolute;right:-5px;top:16px;bottom:16px;width:2px;background:rgba(204,108,5,.35)}.mirror-left span{color:var(--text-muted);font-size:.86rem}.mirror-right{background:var(--navy);border:1px solid rgba(27,42,74,.2)}.mirror-right span{color:var(--white);font-size:.86rem;font-weight:500} @media (max-width:700px){.mirror-row{grid-template-columns:1fr}} @media (max-width: 600px) { .matrix-container { padding: 0 16px; } .matrix-header, .matrix-row { grid-template-columns: 1fr; } .matrix-header-left { border-radius: 8px 8px 0 0; } .matrix-header-right { border-radius: 0 0 8px 8px; } .matrix-row-left { border-radius: 8px 8px 0 0; } .matrix-row-right { border-radius: 0 0 8px 8px; border-left: 2px solid var(--navy); } } /* Micro assurance text */ .micro-assurance { display: block; font-size: 0.8rem; color: var(--text-muted); margin-top: 12px; text-align: center; } .hero-left .micro-assurance { color: rgba(255,255,255,0.5); } .final-cta .micro-assurance { color: rgba(255,255,255,0.6); } /* Flywheel labels */ .flywheel { --flywheel-label-gap: 14px; } .flywheel-label { position: absolute; font-size: 0.68rem; font-weight: 700; color: var(--navy); text-transform: uppercase; letter-spacing: 0.9px; white-space: nowrap; z-index: 4; line-height: 1; pointer-events: none; } .flywheel-label.l1 { top: calc(50% - 100px - 36px - var(--flywheel-label-gap)); left: 50%; transform: translate(-50%, -100%); } .flywheel-label.l2 { top: calc(50% + 50px + 36px + var(--flywheel-label-gap)); left: calc(50% - 86.6px); transform: translateX(-50%); } .flywheel-label.l3 { top: calc(50% + 50px + 36px + var(--flywheel-label-gap)); left: calc(50% + 86.6px); transform: translateX(-50%); } /* Flywheel caption */ .flywheel-caption { text-align: center; font-size: 0.9rem; color: var(--text-muted); margin-top: 16px; font-style: italic; } /* Arrow between nodes */ .flywheel-arrow { position: absolute; color: var(--gold-dim); font-size: 1rem; } /* Framework Pathway - Luxury 6-step architecture */ .framework { padding: 92px 0; background: linear-gradient(180deg, var(--navy) 0%, #172744 65%, #14213a 100%); position: relative; overflow: hidden; } .framework::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 85% 20%, rgba(204,108,5,0.09), transparent 42%); pointer-events: none; } .framework .container { position: relative; } .framework h2 { font-size: 1.9rem; text-align: center; margin-bottom: 10px; color: var(--white); letter-spacing: -0.5px; position: relative; z-index: 1; } .framework h2 span { color: var(--gold-light); } .framework .section-sub { text-align: center; color: rgba(255,255,255,0.74); margin-bottom: 48px; max-width: 860px; margin-left: auto; margin-right: auto; position: relative; z-index: 1; } .framework-pathway-desktop { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); grid-auto-rows: 1fr; column-gap: 20px; row-gap: 28px; position: relative; max-width: 980px; margin: 0 auto; z-index: 1; } .framework-pathway-desktop::before { content: none; } .framework-step { background: #fbfcff; border: 1px solid rgba(27,42,74,0.16); border-radius: 16px; padding: 9px 12px; min-height: 96px; height: 100%; display: grid; grid-template-columns: 40px 1fr; column-gap: 9px; row-gap: 1px; align-items: center; transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease; position: relative; box-shadow: 0 8px 24px rgba(10, 22, 44, 0.14); z-index: 1; } .framework-step:hover { transform: translateY(-2px); border-color: rgba(204,108,5,0.55); box-shadow: 0 12px 30px rgba(10, 22, 44, 0.2); } .framework-step-head { display: contents; } .framework-step-num, .framework-step-badge { display: none !important; } .framework-step-icon, .framework-step-mobile-icon { width: 36px; height: 36px; border-radius: 50%; background: #14213a; border: 2px solid #CC6C05; color: #F2B36F; display: inline-flex; align-items: center; justify-content: center; font-size: 0.9rem; box-shadow: 0 6px 18px rgba(10,22,44,0.3); flex-shrink: 0; grid-column: 1; grid-row: 1; } .framework-step h4 { grid-column: 2; grid-row: 1; font-size: 0.94rem; color: var(--navy); margin: 0; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; line-height: 1.15; } .framework-step-divider { display: none !important; border: 0 !important; height: 0 !important; margin: 0 !important; padding: 0 !important; } .framework-step p { grid-column: 2; grid-row: 2; font-size: 0.82rem; color: #445168; line-height: 1.3; margin: 0; } .framework-connector, .framework-pathway-mobile { display: none !important; } .layer-stack{max-width:980px;margin:0 auto;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.layer-card{background:#fbfcff;border:1px solid rgba(27,42,74,.18);border-radius:14px;padding:18px 16px;box-shadow:0 12px 28px rgba(10,22,44,.15)}.layer-card header{display:flex;align-items:center;gap:10px;margin-bottom:10px}.layer-card i{width:34px;height:34px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:#14213a;color:var(--gold-light);border:2px solid #CC6C05;font-size:.85rem}.layer-card h4{font-size:.84rem;letter-spacing:.6px;text-transform:uppercase;color:var(--navy)}.layer-card p{font-size:.8rem;color:#445168;margin-bottom:10px;line-height:1.35}.layer-card ul{list-style:none;display:grid;gap:6px}.layer-card li{font-size:.78rem;color:#34445e;padding-left:10px;position:relative}.layer-card li:before{content:'•';position:absolute;left:0;color:var(--gold-dim)}.layer-foundation{margin-top:22px}.layer-top{margin-top:44px}.framework-note{text-align:center;margin-top:20px;color:rgba(255,255,255,.72);font-size:.84rem;letter-spacing:.3px} @media (max-width:900px){.layer-stack{grid-template-columns:1fr 1fr}.layer-foundation,.layer-top{margin-top:0}} @media (max-width:600px){.layer-stack{grid-template-columns:1fr}} @media (max-width: 768px) { .framework { padding: 82px 0; } .framework .section-sub { margin-bottom: 34px; } .framework-pathway-desktop { grid-template-columns: 1fr; grid-auto-rows: 1fr; max-width: 680px; row-gap: 22px; column-gap: 0; } .framework-pathway-desktop::before { content: none; } .framework-step { grid-template-columns: 36px 1fr; min-height: 88px; padding: 8px 10px; column-gap: 8px; } .framework-step h4 { font-size: 0.86rem; } .framework-step p { font-size: 0.76rem; line-height: 1.25; } .framework-step-icon, .framework-step-mobile-icon { width: 32px; height: 32px; font-size: 0.86rem; } } /* TM tight-fix override */
.hero-ctas .btn-outline-gold { letter-spacing: 0 !important; }
.hero-ctas .btn-outline-gold .tm { display: inline-block !important; margin-left: -0.10em !important; margin-right: 0 !important; padding: 0 !important; font-size: 0.52em !important; line-height: 0 !important; vertical-align: super !important; position: relative !important; top: -0.48em !important; color: currentColor !important; letter-spacing: 0 !important;
} 
/* Trust strip force-color override */
.trust-strip { background: #0A1428 !important; }
.trust-strip .trust-line { color: rgba(255,255,255,0.88) !important; }
.trust-strip .trust-logo,
.trust-strip .trust-logos img {
  filter: none !important;
  opacity: 1 !important;
  mix-blend-mode: normal !important;
  background: transparent !important;
  border: 0 !important;
  padding: 0 !important;
  border-radius: 0 !important;
  height: 34px !important;
  width: auto !important;
  max-width: 160px !important;
  object-fit: contain !important;
}

@media (max-width: 900px){ .testimonials-grid{grid-template-columns:1fr !important;} }
.metric-stamp{margin:12px 0 14px;padding:10px 12px;border-left:3px solid var(--gold);background:rgba(204,108,5,0.14);border-radius:8px;display:flex;flex-direction:column;gap:2px}
.metric-label{font-size:.66rem;letter-spacing:.6px;text-transform:uppercase;color:rgba(255,255,255,.72);font-weight:700}
.metric-value{font-size:1rem;line-height:1.2;color:var(--gold-light);font-weight:800}
.metric-time{font-size:.72rem;color:rgba(255,255,255,.74)}
@media (max-width:900px){.testimonials-grid{grid-template-columns:1fr !important;}}
</style>
</head>
<body> <nav> <div class="container"> <div class="logo-group"> <div class="logo-mark"> <a href="#" class="logo">REIGNITE</a><span class="logo-dot">.</span> </div> <span class="logo-sub">Advisors</span> </div> <a href="https://calendly.com/mposha-malanga/30min" class="btn btn-gold nav-cta" target="_blank"><i class="fas fa-drafting-compass"></i> Apply for Private Advisory</a> </div> </nav> <section class="hero"> <div class="hero-left"> <div class="hero-tag">Intellectual Asset Architecture</div> <h1>Your Expertise Is Proven. Your Offer Is Still Underpriced.</h1> <p class="hero-sub">You've built real judgment over years, but without structure it has weak market signal. REIGNITE is a private engagement where we codify your expertise, package it into a premium offer, and build leverage beyond your constant presence.</p> <div class="hero-ctas"> <a href="#momentum-score" class="btn btn-gold"> <i class="fas fa-drafting-compass"></i> Apply for Private Advisory </a> <a href="#momentum-score" class="btn btn-outline-gold"> <i class="fas fa-sitemap"></i> See Your Momentum Path </a> <span class="micro-assurance">Limited private slots each month. Qualified applicants only.</span> </div> </div> <div class="hero-right"> <div class="hero-image-wrapper"> <img src="steven-headshot-transparent.png" alt="Steven Tshakatumba"> </div> <div class="hero-wordmark">REIGNITE</div> </div> </section> <section class="trust-strip"> <div class="container"> <p>Trusted by operators and leaders from enterprise, finance, and growth-stage organizations</p> <div class="trust-marquee"> <div class="trust-logos" aria-label="Trust logos"><div class="trust-logo"><img src="/steven/logo-tsx.png?v=12" alt="TSX"></div>
<div class="trust-logo"><img src="/steven/logo-kpmg.png?v=12" alt="KPMG"></div>
<div class="trust-logo"><img src="/steven/logo-stradig.png?v=12" alt="Stradig"></div>
<div class="trust-logo"><img src="/steven/logo-whycoach.png?v=12" alt="WHY Coach"></div>
<div class="trust-logo"><img src="/steven/logo-salesforce.png?v=12" alt="Salesforce"></div>
<div class="trust-logo"><img src="/steven/logo-1.png?v=12" alt="Reignite"></div>
<div class="trust-logo"><img src="/steven/logo-tsx.png?v=12" alt="TSX"></div>
<div class="trust-logo"><img src="/steven/logo-kpmg.png?v=12" alt="KPMG"></div>
<div class="trust-logo"><img src="/steven/logo-stradig.png?v=12" alt="Stradig"></div>
<div class="trust-logo"><img src="/steven/logo-whycoach.png?v=12" alt="WHY Coach"></div>
<div class="trust-logo"><img src="/steven/logo-salesforce.png?v=12" alt="Salesforce"></div>
<div class="trust-logo"><img src="/steven/logo-1.png?v=12" alt="Reignite"></div></div> </div> </section> <section class="why"> <div class="container"> <h2>Your Experience Is Real. Your Market Signal Is Weak.</h2> <p class="section-sub">The core bottleneck is not intelligence. It's architecture. Undocumented experience is hard to signal, hard to package, and hard to price at a premium.</p> <ul class="why-bullets"> <li>Unclear positioning <span>→</span> weak demand</li> <li>Offer sprawl <span>→</span> low conversion</li> <li>Time-for-money <span>→</span> no leverage</li> </ul> <div class="why-grid"> <div class="why-card why-card-left"> <h3>Before</h3> <ul> <li>Hourly advisory sold as loose services</li> <li>Positioning built on personality alone</li> <li>Generalist consulting without defensible IP</li> </ul> </div> <div class="why-card why-card-right"> <h3>After</h3> <ul> <li>A codified Intellectual Asset Architecture</li> <li>Premium fixed-fee offer design</li> <li>A repeatable demand system for right-fit buyers</li> </ul> </div> </div> </div> </section> <!-- Anti-Pattern Stack --> <section class="anti-pattern"> <div class="container"> <h2>Your Expertise Isn't <span>Weak. Your Signal Is.</span></h2> <p class="section-sub">You have deep experience. But without proper packaging, the market only receives a diluted signal of your real value.</p> <style>.signal-wrap{max-width:960px;margin:0 auto 16px;padding:8px 0;background:transparent}.signal-desktop,.signal-mobile{width:100%;height:auto;display:block}.signal-mobile{display:none}.signal-line{stroke:rgba(27,42,74,.64);stroke-width:5;fill:none;stroke-linecap:round}@media (max-width:700px){.signal-desktop{display:none}.signal-mobile{display:block}}</style> <div class="signal-wrap"> <svg class="signal-desktop" viewBox="0 0 980 240" aria-label="Hourglass signal bottleneck desktop"> <!-- bottle/hourglass contour with open-left and neck gap --> <path class="signal-line" d="M286 30 C340 30, 390 58, 430 94 C452 102, 460 104, 468 104"/> <path class="signal-line" d="M286 194 C340 194, 390 166, 430 130 C452 122, 460 120, 468 120"/>   <!-- dense left field stronger toward neck --> <defs><clipPath id="leftBottleClip"><path d="M296 42 C352 42,398 64,422 96 C444 103,452 105,458 105 L458 119 C452 119,444 121,422 128 C398 160,352 182,296 182 Z"/></clipPath></defs> <g clip-path="url(#leftBottleClip)"> <circle cx="127.9" cy="49.5" r="5.05" fill="#CC6C05" fill-opacity="0.29"/> <circle cx="127.9" cy="59.7" r="5.29" fill="#CC6C05" fill-opacity="0.26"/> <circle cx="127.9" cy="70.4" r="4.68" fill="#CC6C05" fill-opacity="0.26"/> <circle cx="127.8" cy="82.1" r="5.20" fill="#CC6C05" fill-opacity="0.29"/> <circle cx="127.7" cy="94.7" r="5.16" fill="#CC6C05" fill-opacity="0.31"/> <circle cx="127.5" cy="107.3" r="4.69" fill="#CC6C05" fill-opacity="0.31"/> <circle cx="127.4" cy="119.1" r="5.32" fill="#CC6C05" fill-opacity="0.29"/> <circle cx="127.2" cy="129.9" r="5.00" fill="#CC6C05" fill-opacity="0.26"/> <circle cx="126.9" cy="140.2" r="4.77" fill="#CC6C05" fill-opacity="0.26"/> <circle cx="126.7" cy="150.8" r="5.37" fill="#CC6C05" fill-opacity="0.28"/> <circle cx="126.5" cy="162.5" r="4.85" fill="#CC6C05" fill-opacity="0.31"/> <circle cx="126.2" cy="175.0" r="4.90" fill="#CC6C05" fill-opacity="0.31"/> <circle cx="137.3" cy="51.5" r="5.18" fill="#CC6C05" fill-opacity="0.28"/> <circle cx="137.1" cy="60.4" r="4.73" fill="#CC6C05" fill-opacity="0.29"/> <circle cx="137.1" cy="71.4" r="5.29" fill="#CC6C05" fill-opacity="0.32"/> <circle cx="137.2" cy="83.6" r="5.22" fill="#CC6C05" fill-opacity="0.34"/> <circle cx="137.3" cy="94.1" r="4.73" fill="#CC6C05" fill-opacity="0.34"/> <circle cx="137.6" cy="102.9" r="5.26" fill="#CC6C05" fill-opacity="0.32"/> <circle cx="137.9" cy="112.5" r="5.25" fill="#CC6C05" fill-opacity="0.29"/> <circle cx="138.3" cy="124.4" r="4.72" fill="#CC6C05" fill-opacity="0.28"/> <circle cx="138.7" cy="136.2" r="5.23" fill="#CC6C05" fill-opacity="0.30"/> <circle cx="139.1" cy="145.7" r="5.28" fill